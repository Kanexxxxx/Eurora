# ============================================================
# EURORA LOVE - variaveis locais e de producao
# Copie para .env e preencha antes de rodar ou subir para VPS.
# ============================================================

# BANCO DE DADOS - Supabase / PostgreSQL
# Onde pegar: Supabase > Project Settings > Database > Connection string
# Use a URL pooler/PgBouncer para o app normal.
DATABASE_URL=postgresql://postgres:SENHA@db.SEU_PROJETO.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1

# Usado pelo Prisma para migrations diretas.
# Onde pegar: mesmo painel do Supabase, connection string direta na porta 5432.
DIRECT_URL=postgresql://postgres:SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# SUPABASE STORAGE - upload de fotos e QR codes
# Onde pegar: Supabase > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Onde pegar: Supabase > Project Settings > API > service_role key
# Importante: chave secreta, usada somente no backend.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ASAAS - PIX e Cartao de Credito
# Onde pegar: Asaas > Integracoes > Chaves de API
ASAAS_API_KEY=$aact_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URL oficial de producao da API Asaas.
ASAAS_API_URL=https://api.asaas.com/v3

# Onde pegar: Asaas > Integracoes > Webhooks > Token de autenticacao
ASAAS_WEBHOOK_TOKEN=token-gerado-no-webhook-asaas

# URL PUBLICA DO SITE
# Seu dominio final, sem barra no final.
NEXT_PUBLIC_APP_URL=https://eurora.site

# CRON - protege a rota /api/cron/enviar-mensagens
# Como gerar: openssl rand -hex 32
CRON_SECRET=coloque-aqui-um-token-seguro-com-32-chars-ou-mais

# RESEND - envio de email programado
# Onde pegar: Resend > API Keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Email remetente verificado no Resend.
# Onde configurar: Resend > Domains
RESEND_FROM_EMAIL=no-reply@eurora.site

# IA ROMANTICA - opcional
# Onde pegar: Anthropic Console > API Keys
# Se vazio, o sistema usa templates locais.
ANTHROPIC_API_KEY=

# CONTATO PUBLICO
# Numero com DDI e DDD, apenas digitos. Ex: 5511999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999
NEXT_PUBLIC_SUPPORT_EMAIL=oi@eurora.site

NODE_ENV=development
