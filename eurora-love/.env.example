# ============================================================
# EURORA LOVE - variaveis locais e de producao
# Copie para .env e preencha antes de rodar ou subir para VPS.
# ============================================================

# BANCO DE DADOS - PostgreSQL local na VPS
# Como criar: veja DEPLOY_VPS.md > PostgreSQL local.
DATABASE_URL=postgresql://eurora:SENHA_FORTE@127.0.0.1:5432/eurora_love
DIRECT_URL=postgresql://eurora:SENHA_FORTE@127.0.0.1:5432/eurora_love

# UPLOADS LOCAIS - fotos dos clientes e QR codes
# Na VPS, use /var/www/eurora/uploads e configure o Nginx para servir /uploads.
UPLOAD_DIR=/var/www/eurora/uploads
UPLOAD_PUBLIC_URL=https://eurora.site/uploads

# ASAAS - PIX e Cartao de Credito
# Onde pegar: Asaas > Integracoes > Chaves de API
ASAAS_API_KEY=$aact_prod_SUA_CHAVE_DE_PRODUCAO_AQUI

# URL oficial de producao da API Asaas.
ASAAS_API_URL=https://api.asaas.com/v3

# Onde pegar: Asaas > Integracoes > Webhooks > Token de autenticacao
ASAAS_WEBHOOK_TOKEN=token-gerado-no-webhook-asaas

# URL PUBLICA DO SITE
# Seu dominio final, sem barra no final.
NEXT_PUBLIC_APP_URL=https://eurora.site

# CRON - protege a rota /api/cron/enviar-mensagens
# Como gerar: openssl rand -hex 32
CRON_SECRET=coloque-aqui-um-token-seguro-com-32-chars-ou-mais

# GMAIL - envio de emails (notificacoes de venda e mensagens programadas)
# Use uma Conta Google com "Senhas de app" habilitada (2FA ativo).
# Onde gerar: Google Account > Seguranca > Senhas de app
GMAIL_USER=seu-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# IA ROMANTICA - opcional
# Onde pegar: Anthropic Console > API Keys
# Se vazio, o sistema usa templates locais (sem custo).
ANTHROPIC_API_KEY=

# CONTATO PUBLICO
# Numero com DDI e DDD, apenas digitos. Ex: 5511999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999
NEXT_PUBLIC_SUPPORT_EMAIL=eurora.com.br@gmail.com

# ADMIN PANEL - senha de acesso ao painel admin em /admin
# Como gerar: openssl rand -hex 16
ADMIN_PASSWORD=coloque-aqui-uma-senha-forte-para-o-admin

NODE_ENV=production
