# ============================================================
# EURORA LOVE — Variáveis de Ambiente (exemplo)
# Copie para .env.local e preencha os valores reais
# ============================================================

# Banco de dados (Prisma + PostgreSQL)
# Connection string do Supabase: Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Supabase (Storage de fotos e QR codes)
# Painel: https://supabase.com/dashboard/project/<seu-projeto>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Mercado Pago
# Painel: https://www.mercadopago.com.br/developers/panel/app
# Use TEST-xxx para sandbox, PROD-xxx para produção
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_WEBHOOK_SECRET=

# Anthropic (IA Romântica — claude-haiku)
# Painel: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# Resend (envio de e-mails agendados)
# Painel: https://resend.com/api-keys
RESEND_API_KEY=re_xxx

# Cron (autenticação do endpoint de envio automático)
# Gere: openssl rand -hex 32
CRON_SECRET=gere-um-valor-seguro

# URL pública (sem barra no final)
NEXT_PUBLIC_APP_URL=https://eurora.love.br

# Contato
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999
NEXT_PUBLIC_SUPPORT_EMAIL=oi@eurora.love.br
